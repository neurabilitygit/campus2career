{
  "name": "@rising-senior/api",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "node --watch --env-file=.env.local --import tsx/esm src/index.ts",
    "dev:test": "ALLOW_DEMO_AUTH=true node --watch --env-file=.env.local --import tsx/esm src/index.ts",
    "typecheck": "tsc --noEmit",
    "test": "node --import tsx/esm --test 'src/**/*.test.ts'",
    "test:unit": "node --import tsx/esm --test --test-concurrency=1 'src/services/**/*.test.ts' 'src/http/**/*.test.ts' 'src/db/**/*.test.ts'",
    "test:integration": "node --env-file=.env.local --import tsx/esm --test --test-concurrency=1 'src/routes/**/*.test.ts'",
    "test:seed:e2e": "tsx --env-file=.env.local src/scripts/seedTestHarnessData.ts",
    "db:migrate": "node --env-file=.env.local --import tsx/esm src/scripts/applyDbMigrations.ts",
    "db:seed:institutions": "node --env-file=.env.local --import tsx/esm src/scripts/seedInstitutionDirectoryBootstrap.ts",
    "db:seed:ci": "node --env-file=.env.local --import tsx/esm src/scripts/seedCiBaseline.ts",
    "market:refresh": "node --env-file=.env.local --import tsx/esm src/scripts/refreshMarketReferenceData.ts",
    "synthetic:run": "node --env-file=.env.local --import tsx/esm src/scripts/runSyntheticScenarios.ts",
    "academic:discover:smoke": "node --env-file=.env.local --import tsx/esm src/scripts/runAcademicDiscoverySmoke.ts",
    "academic:discover:seed": "node --env-file=.env.local --import tsx/esm src/scripts/runAcademicDiscoverySeed.ts",
    "academic:discover:top50": "node --env-file=.env.local --import tsx/esm src/scripts/runAcademicDiscoveryTop50.ts",
    "academic:review:top50": "node --env-file=.env.local --import tsx/esm src/scripts/runAcademicDiscoveryTop50Review.ts"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.49.1",
    "jose": "^5.9.6",
    "openai": "^4.104.0",
    "pg": "^8.16.3",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/node": "^22.10.5",
    "@types/pg": "^8.11.11",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2"
  }
}
